# OpenAI
OPENAI_API_KEY=sk-...

# Tavily (web search)
TAVILY_API_KEY=tvly-...

# MCP Diagnosis Service
MCP_DIAGNOSIS_BASE_URL=https://your-mcp-service.com
MCP_DIAGNOSIS_AUTH_TOKEN=your-auth-token
MCP_DIAGNOSIS_TIMEOUT_SECONDS=30

RAGIE_API_KEY=your-ragie-api-key

# Cloud Run / production auth: comma-separated raw API keys (no spaces). When set, SQLite keys in auth/auth.db are ignored.
# Store as a single Secret Manager secret for deploy (see docs/olympus-ai-backend/DEPLOY_GCP.md).
# AUTH_API_KEY=sk_one,sk_two
# For GCP/Cloud Run, store these keys in the Secret Manager secret: OLYMPUS_AUTH_API_KEY
